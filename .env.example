# Copy this file to .env and replace only local secret values.
PORT=3000
BENZ_AI_HOST_PORT=3000
GIT_COMMIT_SHA=
GIT_COMMIT_DATE=

# Sber Chromium worker: cached areas expire after 15 minutes; the browser
# closes 30 seconds later when no user request or refresh is in progress.
SBER_REFRESH_MS=60000
SBER_ACTIVE_AREA_TTL_MS=900000
SBER_MAX_ACTIVE_AREAS=10
SBER_BROWSER_IDLE_MS=30000

# Alfa returns a nationwide snapshot; cache it once and filter locally.
ALFA_AZS_CACHE_TTL_MS=60000
ALFA_AZS_TIMEOUT_MS=30000
ALFA_AZS_ZOOM=14

# Telegram is disabled until both values are configured.
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_BOT_TOKEN=replace-with-token
TELEGRAM_API_BASE_URL=https://api.telegram.org

# DeepSeek is available to future bot workflows but is not called by the
# current fuel-search command.
DEEPSEEK_API_KEY=replace-with-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=60000
